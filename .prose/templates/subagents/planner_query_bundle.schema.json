{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "template": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "subagent_patch_bundle"
      ]
    },
    "stage": {
      "type": "string",
      "enum": [
        "planner_subagent"
      ]
    },
    "subagent_id": {
      "type": "string",
      "enum": [
        "planner_agent"
      ]
    },
    "subagent_role": {
      "type": "string",
      "enum": [
        "query_planner"
      ]
    },
    "parent_agent": {
      "type": "string",
      "enum": [
        "prose_research_agent"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "shadow"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "current_run"
      ]
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "lane": {
      "type": [
        "string",
        "null"
      ]
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "subagent_runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_slot": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolved_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolved_alias": {
          "type": [
            "string",
            "null"
          ]
        },
        "filled_by_runtime": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "model_slot",
        "resolved_model",
        "resolved_alias",
        "filled_by_runtime",
        "notes"
      ]
    },
    "openprose_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "program_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "bindings_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "integration_mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "controller_contract": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "program_file",
        "run_dir",
        "bindings_dir",
        "integration_mode",
        "controller_contract"
      ]
    },
    "based_on": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "orchestration_plan": {
          "type": [
            "string",
            "null"
          ]
        },
        "coverage_report": {
          "type": [
            "string",
            "null"
          ]
        },
        "controller_decision": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_memory": {
          "type": [
            "string",
            "null"
          ]
        },
        "ranked_candidate_digest": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "orchestration_plan",
        "coverage_report",
        "controller_decision",
        "run_memory",
        "ranked_candidate_digest"
      ]
    },
    "problem_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "missing_angles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "short_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "salience_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "noise_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "recency_note": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "missing_angles",
        "short_note",
        "salience_note",
        "noise_note",
        "recency_note"
      ]
    },
    "topic_alternatives": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "alternative_id": {
            "type": "string",
            "minLength": 1
          },
          "alternative_topic": {
            "type": [
              "string",
              "null"
            ]
          },
          "concept_emphasis": {
            "type": "string",
            "enum": [
              "canonical",
              "biomarker_focused",
              "predictor_focused",
              "response_focused",
              "inflammatory_focused",
              "broad_condition_focused",
              "intervention_focused"
            ]
          },
          "rationale": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "alternative_id",
          "alternative_topic",
          "concept_emphasis",
          "rationale"
        ]
      }
    },
    "candidate_queries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "family_id": {
            "type": "string"
          },
          "topic_alternative_id": {
            "type": "string"
          },
          "family_strategy": {
            "type": "string",
            "enum": [
              "precision_primary",
              "broad_primary",
              "observational_primary",
              "accessibility_biased",
              "review_exclusion",
              "recency_biased"
            ]
          },
          "label": {
            "type": "string"
          },
          "action_family": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "boost_primary_study_queries",
              "broaden_query_or_raise_top_k",
              "prefer_accessible_records",
              null
            ]
          },
          "backend_queries": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "pubmed_query": {
                "type": "string",
                "minLength": 25,
                "pattern": ".*[A-Za-z].*"
              },
              "europe_pmc_query": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "query_backend_notes": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "pubmed_query",
              "europe_pmc_query",
              "query_backend_notes"
            ]
          },
          "query_changes": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "append_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 8
              },
              "append_phrases": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 4
              },
              "remove_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 4
              },
              "remove_phrases": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 2
              },
              "preserve_existing_terms": {
                "type": "boolean"
              }
            },
            "required": [
              "append_terms",
              "append_phrases",
              "remove_terms",
              "remove_phrases",
              "preserve_existing_terms"
            ]
          },
          "search_overrides": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "hybrid",
                  "accessible",
                  null
                ]
              },
              "journal_set": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "tier1",
                  "tier2",
                  "tier1_tier2",
                  "off",
                  null
                ]
              },
              "max_results_multiplier": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 1.0,
                "maximum": 1.5
              },
              "per_query_multiplier": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 1.0,
                "maximum": 1.5
              }
            },
            "required": [
              "mode",
              "journal_set",
              "max_results_multiplier",
              "per_query_multiplier"
            ]
          },
          "rank_overrides": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "journal_priority": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "default",
                  "strict",
                  null
                ]
              },
              "max_per_journal": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1,
                "maximum": 2
              }
            },
            "required": [
              "journal_priority",
              "max_per_journal"
            ]
          },
          "why_this_candidate": {
            "type": [
              "string",
              "null"
            ]
          },
          "retained_must_have_concepts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dropped_must_have_concepts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "optional_concepts_used": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "broadening_concepts_used": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "concept_coverage_note": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "family_id",
          "topic_alternative_id",
          "family_strategy",
          "label",
          "action_family",
          "backend_queries",
          "query_changes",
          "search_overrides",
          "rank_overrides",
          "why_this_candidate",
          "retained_must_have_concepts",
          "dropped_must_have_concepts",
          "optional_concepts_used",
          "broadening_concepts_used",
          "concept_coverage_note"
        ]
      }
    },
    "selection_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_single_family": {
          "type": "boolean"
        },
        "allow_hybrid_family_merge": {
          "type": "boolean"
        },
        "prefer_explicit_backend_queries": {
          "type": "boolean"
        },
        "require_distinct_family_strategies": {
          "type": "boolean"
        },
        "allow_multiple_topic_alternatives": {
          "type": "boolean"
        },
        "topic_alternative_count_target": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "max_families_to_eval": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        }
      },
      "required": [
        "allow_single_family",
        "allow_hybrid_family_merge",
        "prefer_explicit_backend_queries",
        "require_distinct_family_strategies",
        "allow_multiple_topic_alternatives",
        "topic_alternative_count_target",
        "max_families_to_eval"
      ]
    },
    "evaluation_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "branch_type": {
          "type": "string",
          "enum": [
            "cheap_eval"
          ]
        },
        "stop_after_stage": {
          "type": "string",
          "enum": [
            "fulltext_resolve"
          ]
        },
        "compare_against": {
          "type": [
            "string",
            "null"
          ]
        },
        "success_metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "target_deltas": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "primary_study_like_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "semantic_ready_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                }
              },
              "required": [
                "primary_study_like_count",
                "semantic_ready_count"
              ]
            },
            "must_not_decrease": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "guardrails": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min_fulltext_yield_rate": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "max_review_to_primary_ratio": {
                  "type": [
                    "number",
                    "null"
                  ]
                }
              },
              "required": [
                "min_fulltext_yield_rate",
                "max_review_to_primary_ratio"
              ]
            }
          },
          "required": [
            "target_deltas",
            "must_not_decrease",
            "guardrails"
          ]
        }
      },
      "required": [
        "branch_type",
        "stop_after_stage",
        "compare_against",
        "success_metrics"
      ]
    },
    "confidence": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        null
      ]
    },
    "planner_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "concept_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "must_have_concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional_concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "broadening_concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "require_at_least_one_family_to_preserve_all_must_have": {
          "type": "boolean"
        },
        "target_families_preserving_all_must_have": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        }
      },
      "required": [
        "must_have_concepts",
        "optional_concepts",
        "broadening_concepts",
        "require_at_least_one_family_to_preserve_all_must_have",
        "target_families_preserving_all_must_have"
      ]
    }
  },
  "required": [
    "schema_version",
    "template",
    "artifact_type",
    "stage",
    "subagent_id",
    "subagent_role",
    "parent_agent",
    "mode",
    "scope",
    "run_id",
    "lane",
    "generated_at",
    "subagent_runtime",
    "openprose_context",
    "based_on",
    "problem_summary",
    "concept_policy",
    "topic_alternatives",
    "candidate_queries",
    "selection_intent",
    "evaluation_plan",
    "confidence",
    "planner_note"
  ]
}
